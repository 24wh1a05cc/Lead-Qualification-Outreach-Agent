# ── Environment & Secrets ─────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Runtime audit log ─────────────────────────────────────────────────────────
# The live runtime file at the project root is excluded (it grows unboundedly).
# The seed file committed for first-load demo is kept via the negation below.
/audit_log.jsonl
!audit_log.seed.jsonl

# ── Eval reports (generated artifacts) ───────────────────────────────────────
# The live generated reports are excluded; committed seed copies are kept.
/eval/eval_report.json
/eval/eval_report.md
!eval/eval_report.seed.json

# ── Distribution / packaging ──────────────────────────────────────────────────
dist/
build/
*.egg-info/
*.egg
.eggs/

# ── Testing ───────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/

# ── Type checking ─────────────────────────────────────────────────────────────
.mypy_cache/
.pyright/

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ── IDEs ──────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
