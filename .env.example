# ── Lead Qualification & Outreach Agent — Environment Variables ──────────────
# Copy this file to .env and fill in real values. Never commit .env to git.

# OpenRouter API key (required for LLM email drafting)
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# Model to use via OpenRouter (optional — defaults to openai/gpt-4o-mini)
# Other options: anthropic/claude-3.5-sonnet, mistralai/mistral-7b-instruct, etc.
# Full list: https://openrouter.ai/models
OPENROUTER_MODEL=openai/gpt-4o-mini

# Optional: override the default audit log path (default: ./audit_log.jsonl)
# AUDIT_LOG_PATH=/var/log/lead-agent/audit_log.jsonl
